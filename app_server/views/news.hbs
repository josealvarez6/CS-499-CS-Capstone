<!DOCTYPE html>
<!-- Website template by freewebsitetemplates.com -->
<html>
<head>
	<meta charset="UTF-8">
	<title>News - Travlr Getaways Website Template</title>
	<link rel="stylesheet" href="css/style.css" type="text/css">
</head>
<body>
	<div id="background">
		<div id="page">
			{{> header}}
			<div id="contents">
				<div class="box">
					<div>
						<div id="news" class="body">
							<div class="sidebar">
								<h3>Latest News</h3>
								<ul>
			{{#each stories.latest}}
									<li>
										<a href="news.html">{{this}}</a>
									</li>
			{{/each}}
								</ul>
								<h3>Vacation Tips</h3>
								<ul>
			{{#each stories.tips}}
									<li>
										<a href="news.html">{{this}}</a>
									</li>
			{{/each}}
								</ul>
							</div>
							<div>
								<h1>News</h1>
								<img src="images/kayak.jpg" alt="Img">
								<h2>{{stories.articles.[0].title}}</h2>
								<span class="time">{{stories.articles.[0].date}}<br> by: {{stories.articles.[0].author}}</span>
			{{#each stories.articles.[0].paragraphs}}
								<p>
									{{this}}
								</p>
			{{/each}}
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		{{> footer}}
	</div>
</body>
</html>