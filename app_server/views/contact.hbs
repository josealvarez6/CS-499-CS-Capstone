<!DOCTYPE html>
<!-- Website template by freewebsitetemplates.com -->
<html>
<head>
	<meta charset="UTF-8">
	<title>{{contact.pageTitle}}</title>
	<link rel="stylesheet" href="/css/style.css" type="text/css">
</head>
<body>
	<div id="background">
		<div id="page">
			{{> header}}
			<div id="contents">
				<div class="box">
					<div>
						<div id="contact" class="body">
							<h1>{{contact.heading}}</h1>

							<form action="/" method="post">
								<table>
									<tbody>
			{{#each contact.formFields}}
										<tr>
											<td class="{{#if isTextarea}}txtarea{{/if}}">{{label}}</td>
											<td>
												{{#if isTextarea}}
												<textarea></textarea>
												{{else}}
												<input type="{{type}}" value="" class="txtfield">
												{{/if}}
											</td>
										</tr>
			{{/each}}
										<tr>
											<td></td>
											<td><input type="submit" value="" class="btn"></td>
										</tr>
									</tbody>
								</table>
							</form>

							<h2>{{contact.company}}</h2>

			{{#each contact.details}}
							<p>
								<span>{{label}}</span> {{value}}
							</p>
			{{/each}}
						</div>
					</div>
				</div>
			</div>
		</div>
		{{> footer}}
	</div>
</body>
</html>